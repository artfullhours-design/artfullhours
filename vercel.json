{
  "version": 2,
  "buildCommand": "echo 'Static build complete'",
  "installCommand": "npm install && cd server && npm install && cd ..",
  "public": "client",
  "functions": {
    "server/server.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "server/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
